# Base de datos (Neon PostgreSQL)
# Obtener en: https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
# Generar con: openssl rand -hex 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Google OAuth (para login de MEMBER)
# Configurar en: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (para emails del newsletter)
# Obtener en: https://resend.com
RESEND_API_KEY=""

# URL pública del sitio
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Cloudinary (para subida de imágenes)
# Obtener en: https://cloudinary.com → Settings → Upload → Upload presets
# Crear un preset de tipo "Unsigned" para uploads desde el browser
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Upstash Redis (para rate-limiting de vistas)
# Obtener en: https://upstash.com → Redis → Create database → REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
