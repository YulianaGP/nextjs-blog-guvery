// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooler — usado por Prisma Client en runtime
  directUrl = env("DIRECT_URL")  // conexión directa — usada por Prisma CLI (migrate, studio)
}

// ─── USUARIO ──────────────────────────────────────────────────────────────────

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  password      String?     // Hash bcrypt — solo para Credentials provider (STAFF)
  accountType   AccountType @default(MEMBER)
  role          Role?       // Solo relevante para STAFF (ADMIN | EDITOR)

  // Campos del perfil público del autor (solo STAFF con rol editorial)
  slug String? @unique // URL pública: /autor/[slug]
  bio  String? // Descripción corta visible en la página del autor

  // Relaciones NextAuth
  accounts Account[]
  sessions Session[]

  // Relaciones del blog
  posts    Post[]
  comments Comment[]

  // Relaciones de notificaciones
  receivedNotifications Notification[] @relation("ReceivedNotifications")
  sentNotifications     Notification[] @relation("SentNotifications")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountType])
  @@index([role])
  @@map("users")
}

// Separa el tipo de cuenta del rol editorial
// STAFF  → equipo interno (ADMIN/EDITOR), accede al dashboard
// MEMBER → usuarios de la plataforma Guvery (compradores/viajeros), solo blog
enum AccountType {
  STAFF
  MEMBER
}

// Solo aplica a usuarios STAFF
enum Role {
  ADMIN
  EDITOR
}

// ─── NEXTAUTH — Modelos requeridos por el adapter ─────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── ARTÍCULO ─────────────────────────────────────────────────────────────────

model Post {
  id      String @id @default(cuid())
  title   String
  slug    String @unique
  excerpt String // Resumen corto para listados y meta description
  content String @db.Text // HTML generado por el editor (Tiptap)

  coverImage  String? // URL de imagen destacada (Cloudinary / Vercel Blob)
  ogImage     String? // URL de imagen para OpenGraph/RRSS — puede diferir de coverImage
  featured    Boolean    @default(false) // Para destacar artículos en el home (HU14)
  status      PostStatus @default(DRAFT)
  // NOTA DE ARQUITECTURA: si el blog crece mucho, `views` puede generar locks
  // por las actualizaciones concurrentes. Alternativa: acumular en Redis y
  // sincronizar periódicamente en un cron job.
  views       Int        @default(0) // Para ordenar artículos populares (HU14)
  readingTime Int? // Minutos estimados de lectura

  // Campos SEO opcionales — pueden diferir del título/excerpt visible
  metaTitle       String?
  metaDescription String?

  // Relaciones
  author        User           @relation(fields: [authorId], references: [id])
  authorId      String
  category      Category       @relation(fields: [categoryId], references: [id])
  categoryId    String
  tags          Tag[]          @relation("PostTags")
  notifications Notification[]
  comments      Comment[]

  // Timestamps
  publishedAt DateTime? // Índice incluido: útil para "Últimos artículos" y sitemap
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt // Expuesto en HU19 (fecha de actualización)

  @@index([slug])
  @@index([authorId]) // Optimiza getAuthorPosts() — listado de artículos propios del editor
  @@index([categoryId])
  @@index([status])
  @@index([views])
  @@index([publishedAt]) // Optimiza queries de "artículos recientes" y sitemap
  @@index([featured]) // Optimiza queries de artículos destacados en el home
  @@index([authorId, status]) // Optimiza "mis artículos pendientes/publicados" (filtro compuesto)
  @@map("posts")
}

enum PostStatus {
  DRAFT      // Autor escribiendo
  REVIEW     // Enviado al admin para revisión
  PUBLISHED  // Admin publicó
  ARCHIVED   // Desactivado
}

// ─── CATEGORÍA ────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String? // Color hex para el badge visual (ej: "#E86C2C")
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

// ─── TAG ──────────────────────────────────────────────────────────────────────

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("PostTags")

  @@map("tags")
}

// ─── SUSCRIPTOR ───────────────────────────────────────────────────────────────

model Subscriber {
  id    String @id @default(cuid())
  email String @unique
  name  String?

  status      SubscriberStatus @default(PENDING)
  // Token UUID para el link de confirmación de suscripción (double opt-in)
  // Ejemplo de uso: /newsletter/confirmar?token=<confirmationToken>
  confirmationToken String?   @unique
  confirmedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  source    String? // "blog-footer" | "post-inline" | "sidebar"

  @@index([email])
  @@index([status])
  @@index([confirmationToken])
  @@map("subscribers")
}

enum SubscriberStatus {
  PENDING // Email ingresado, pendiente de confirmación
  CONFIRMED // Confirmó su suscripción vía token
  UNSUBSCRIBED // Se dio de baja
}

// ─── COMENTARIO ───────────────────────────────────────────────────────────────

model Comment {
  id      String        @id @default(cuid())
  content String        @db.Text // Texto plano — sin HTML
  status  CommentStatus @default(APPROVED)

  // Relaciones
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId, status]) // Optimiza "comentarios aprobados de este post"
  @@map("comments")
}

enum CommentStatus {
  PENDING  // Pendiente de moderación (para uso futuro)
  APPROVED // Visible públicamente (default actual)
}

// ─── NOTIFICACIÓN ─────────────────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  message String

  // Destinatario de la notificación
  userId String
  user   User   @relation("ReceivedNotifications", fields: [userId], references: [id], onDelete: Cascade)

  // Quién generó la notificación (autor o admin)
  fromId String?
  from   User?   @relation("SentNotifications", fields: [fromId], references: [id], onDelete: SetNull)

  // Artículo relacionado (opcional — puede haberse eliminado)
  postId String?
  post   Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)

  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Índices optimizados para las queries más frecuentes:
  @@index([userId])                // "dame todas las notifs del usuario X"
  @@index([userId, read])          // "dame las notifs NO leídas del usuario X" (badge del header)
  @@index([userId, createdAt])     // "dame las últimas N notifs del usuario X" (ordenadas)
  @@index([postId])                // "dame todas las notifs asociadas al artículo Y"
  @@map("notifications")
}

enum NotificationType {
  POST_SUBMITTED      // Autor envió artículo a revisión → notifica a admins
  POST_APPROVED       // Admin publicó el artículo → notifica al autor
  POST_REJECTED       // Admin rechazó el artículo → notifica al autor
  POST_NEEDS_REVISION // Admin solicita cambios → notifica al autor
}
